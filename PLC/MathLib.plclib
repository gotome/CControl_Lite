			<struct name="strRealPoint" version="1.0.0">
				<vars>
					<var name="x" type="REAL"/>
					<var name="y" type="BOOL"/>
				</vars>
				<iecDeclaration active="FALSE"/>
			</struct>
		</structs>
		<typedefs>
			<typedef name="ARR_RealPoint16" type="strRealPoint" idxMin0="1" idx0="16">
				<iecDeclaration active="FALSE"/>
			</typedef>
		</typedefs>
